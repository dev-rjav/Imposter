# Copy this file to .env and adjust as needed.
# None of these are required — sensible defaults are baked into config.js.

# Port the HTTP + WebSocket server listens on.
PORT=3000

# Max players allowed in a single room.
MAX_PLAYERS_PER_ROOM=10

# Minimum players the host needs before starting a round.
MIN_PLAYERS_TO_START=3

# How many previous sets a room remembers, to avoid repeating
# the same category/word pairing too soon.
SET_HISTORY_SIZE=20

# Delay (ms) between roles being assigned and the first describer's turn,
# giving everyone a moment to read their word/question.
ROLE_REVEAL_DELAY_MS=5000
